rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin emails list — readable by any authenticated user (no sensitive data)
    match /config/admins {
      allow read: if request.auth != null;
      allow write: if false; // Write only via Admin SDK (Cloud Functions)
    }

    // Jobs — readable/creatable by any authenticated user
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Stories — readable by any authenticated user
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
